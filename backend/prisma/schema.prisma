generator client {
  provider = "prisma-client-js"
  // build for native (local dev) plus linux musl ARM64 for Docker on Apple silicon
  binaryTargets = ["native", "linux-musl-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  todo
  in_progress
  done
}

model Todo {
  id          Int      @id @default(autoincrement())
  text        String
  status      Status   @default(todo)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime? // timestamp when marked done, optional
}
